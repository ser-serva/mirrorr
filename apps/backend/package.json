{
  "name": "@mirrorr/backend",
  "version": "0.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc",
    "dev": "tsx watch --env-file=../../infra/dev/.env src/server.ts",
    "worker:dev": "tsx watch --env-file=../../infra/dev/.env src/worker.ts",
    "migrate": "dotenv -e ../../infra/dev/.env -- drizzle-kit migrate",
    "generate": "dotenv -e ../../infra/dev/.env -- drizzle-kit generate",
    "db:generate": "dotenv -e ../../infra/dev/.env -- drizzle-kit generate",
    "db:migrate": "dotenv -e ../../infra/dev/.env -- drizzle-kit migrate",
    "lint": "eslint . --max-warnings 0",
    "check-types": "tsc --noEmit",
    "test": "vitest run",
    "test:watch": "vitest",
    "test:coverage": "vitest run --coverage"
  },
  "dependencies": {
    "@fastify/cookie": "^11.0.2",
    "@fastify/secure-session": "^8.3.0",
    "@fastify/static": "^8.3.0",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.5",
    "@mirrorr/adapter-core": "workspace:*",
    "@mirrorr/adapter-loops": "workspace:*",
    "@mirrorr/adapter-tiktok": "workspace:*",
    "@mirrorr/shared": "workspace:*",
    "@temporalio/activity": "^1.15.0",
    "@temporalio/client": "^1.15.0",
    "@temporalio/worker": "^1.15.0",
    "@temporalio/workflow": "^1.15.0",
    "better-sqlite3": "^11.10.0",
    "drizzle-orm": "^0.39.3",
    "fastify": "^5.7.4",
    "fastify-type-provider-zod": "^4.0.2",
    "nanoid": "^5.1.6",
    "zod": "^3.25.76"
  },
  "devDependencies": {
    "@repo/typescript-config": "workspace:*",
    "@temporalio/testing": "^1.15.0",
    "@types/better-sqlite3": "^7.6.13",
    "@types/node": "^22.19.11",
    "@types/supertest": "^7.2.0",
    "@vitest/coverage-v8": "^4.0.18",
    "drizzle-kit": "^0.30.6",
    "supertest": "^7.2.2",
    "tsx": "^4.21.0",
    "typescript": "5.9.2",
    "vitest": "^4.0.18"
  }
}
