# Mirrorr — Pre-production environment
# Copy to .env and fill in all values before running docker compose up.
#
# Generate secrets:
#   ENCRYPTION_KEY : openssl rand -hex 32
#   ADMIN_PASSWORD : openssl rand -base64 18
#   SESSION_SECRET : openssl rand -hex 32
#   SESSION_SALT   : openssl rand -hex 8      (exactly 16 hex chars = 8 bytes)
#
# Image tag to deploy — defaults to 'alpha' in compose.yaml.
# Override on the command line: IMAGE_TAG=v0.1.0-alpha.2 docker compose up -d
IMAGE_TAG=alpha

# ── Required secrets ──────────────────────────────────────────────────────────
ENCRYPTION_KEY=
ADMIN_PASSWORD=
SESSION_SECRET=
SESSION_SALT=

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=/data/mirrorr.db

# ── Temporal ──────────────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=mirrorr-pipeline

# ── TikTok auth ───────────────────────────────────────────────────────────────
# Mount cookies into the named 'data' Docker volume before first run:
#   docker run --rm -v mirrorr-preprod_data:/data -v $(pwd)/cookies.txt:/src/cookies.txt \
#     alpine cp /src/cookies.txt /data/cookies/cookies.txt
TIKTOK_COOKIES_FILE=/data/cookies/cookies.txt

# ── Worker concurrency ────────────────────────────────────────────────────────
DOWNLOAD_CONCURRENCY=1
UPLOAD_CONCURRENCY=1

# ── VPN (Gluetun / WireGuard) ─────────────────────────────────────────────────
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_PUBLIC_KEY=
WIREGUARD_PRESHARED_KEY=
WIREGUARD_ADDRESSES=10.x.x.x/32
WIREGUARD_DNS=1.1.1.1

# ── API server ────────────────────────────────────────────────────────────────
PORT=4001
HOST=0.0.0.0
