# ─────────────────────────────────────────────────────────────────────────────
# mirrorr — dev environment configuration
# Copy this file to infra/dev/.env and fill in real values.
# infra/dev/.env is gitignored — never commit secrets.
# ─────────────────────────────────────────────────────────────────────────────

# ── Required secrets (startup exits immediately if any are missing) ───────────

# AES-256 key for encrypting stored API tokens — 64 hex chars (32 bytes)
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Admin dashboard password — minimum 12 characters
ADMIN_PASSWORD=

# Session cookie signing key — minimum 32 characters
SESSION_SECRET=

# Session key derivation salt — exactly 16 characters
SESSION_SALT=

# ── Infrastructure ─────────────────────────────────────────────────────────────

TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=mirrorr-pipeline

# Optional — enables "View in Temporal ↗" deep-links in the frontend
TEMPORAL_UI_URL=http://localhost:8080

# SQLite database file path (relative to the running process, or absolute)
DATABASE_PATH=./data/mirrorr.db

# ── File system paths ──────────────────────────────────────────────────────────

# Netscape cookies.txt for yt-dlp TikTok authentication
TIKTOK_COOKIES_FILE=./data/cookies/cookies.txt

# Optional — live Firefox profile path (overrides cookies file when set).
# Populated by: docker compose --profile dev up -d firefox
# then log in to TikTok at http://localhost:3002 (routed through Gluetun VPN).
# When set, yt-dlp uses --cookies-from-browser instead of TIKTOK_COOKIES_FILE.
# FIREFOX_PROFILE_PATH=/firefox-profile/.config/mozilla/firefox

# ── Worker concurrency (requires worker restart to change) ────────────────────

DOWNLOAD_CONCURRENCY=2
UPLOAD_CONCURRENCY=2
# Max parallel yt-dlp downloads spawned by the worker (default: 3)
MAX_CONCURRENT_DOWNLOADS=2

# ── VPN (Gluetun / WireGuard) ───────────────────────────────────────────────
VPN_SERVICE_PROVIDER=custom
VPN_TYPE=wireguard
WIREGUARD_PRIVATE_KEY=
WIREGUARD_PUBLIC_KEY=
WIREGUARD_PRESHARED_KEY=
WIREGUARD_ADDRESSES=10.x.x.x/32
WIREGUARD_DNS=1.1.1.1

# ── Timezone (used by the firefox container) ──────────────────────────────────
TZ=UTC
