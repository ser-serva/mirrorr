# Mirrorr — Production environment
# Copy to .env and fill in real values before running docker compose up
#
# Generate secrets:
#   ENCRYPTION_KEY : openssl rand -hex 32
#   ADMIN_PASSWORD : openssl rand -base64 18  (must be >= 12 chars)
#   SESSION_SECRET : openssl rand -hex 32
#   SESSION_SALT   : openssl rand -hex 8       (exactly 16 hex chars = 8 bytes)

# ── Required secrets ──────────────────────────────────────────────────────────
ENCRYPTION_KEY=
ADMIN_PASSWORD=
SESSION_SECRET=
SESSION_SALT=

# ── Database ──────────────────────────────────────────────────────────────────
# Path inside the container — mounted from the 'data' Docker volume (/data/...)
DATABASE_PATH=/data/mirrorr.db

# ── Temporal ──────────────────────────────────────────────────────────────────
# temporal is the compose service name — reachable on the internal network
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=mirrorr-pipeline
# TEMPORAL_UI_URL is intentionally omitted in prod; pause/resume via REST API

# ── TikTok auth ───────────────────────────────────────────────────────────────
# Cookies are mounted into the 'data' volume; re-export from browser every ~3 weeks
TIKTOK_COOKIES_FILE=/data/cookies/cookies.txt
# Optional — Firefox profile path inside the worker container.
# Populated by: docker compose --profile tools up -d firefox
# then log in to TikTok at http://localhost:3002
# When set, yt-dlp uses --cookies-from-browser instead of TIKTOK_COOKIES_FILE.
# FIREFOX_PROFILE_PATH=/firefox-profile/.config/mozilla/firefox

# ── Worker concurrency ────────────────────────────────────────────────────────
DOWNLOAD_CONCURRENCY=2
UPLOAD_CONCURRENCY=2

# ── VPN (Gluetun / WireGuard) ─────────────────────────────────────────────────
WIREGUARD_PRIVATE_KEY=
WIREGUARD_PUBLIC_KEY=
WIREGUARD_PRESHARED_KEY=
WIREGUARD_ADDRESSES=10.x.x.x/32
WIREGUARD_DNS=1.1.1.1

# ── API server ────────────────────────────────────────────────────────────────
PORT=4001
HOST=0.0.0.0
