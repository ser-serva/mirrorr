# ── Required secrets ─────────────────────────────────────────────────────────
# Generate: openssl rand -hex 32
ENCRYPTION_KEY=

# Dashboard login password (min 12 chars)
ADMIN_PASSWORD=

# Generate: openssl rand -hex 32
SESSION_SECRET=

# Generate: openssl rand -hex 8  (must be exactly 16 hex chars)
SESSION_SALT=

# ── Temporal ──────────────────────────────────────────────────────────────────
TEMPORAL_ADDRESS=localhost:7233
TEMPORAL_NAMESPACE=default
TEMPORAL_TASK_QUEUE=mirrorr-pipeline

# Optional: set to enable deep-links in the frontend
# TEMPORAL_UI_URL=http://localhost:8080

# ── Database ──────────────────────────────────────────────────────────────────
DATABASE_PATH=./data/mirrorr.db

# ── Worker concurrency ────────────────────────────────────────────────────────
DOWNLOAD_CONCURRENCY=2
UPLOAD_CONCURRENCY=2

# ── TikTok auth ───────────────────────────────────────────────────────────────
TIKTOK_COOKIES_FILE=./data/cookies/cookies.txt
# FIREFOX_PROFILE_PATH=   # Uncomment to use live Firefox profile instead

# ── Server ────────────────────────────────────────────────────────────────────
PORT=4001
HOST=0.0.0.0
